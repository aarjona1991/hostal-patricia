# =============================================================================
# public_html/.htaccess — Hostinger (document root = public_html)
# =============================================================================
# Modo: SPA en la RAÍZ del dominio (/). Los estáticos salen de:
#   public_html/hostal-web/frontend/dist/
# (no hay carpeta public_html/app/ ni URL /app/ con ESTE archivo.)
#
# Otra modalidad (solo si quieres todo bajo /app/): usa
#   deploy/htaccess-opcion-b-subcarpeta-app.example + HOSTINGER_STATIC_SUBDIR=app.
#
# Requisitos:
#   • Monorepo dentro de public_html, ej. public_html/hostal-web/
#   • En .env del VPS: sin HOSTINGER_STATIC_SUBDIR — el build de Vite debe usar
#     base "/" (scripts en /assets/…). Si en .env quedó HOSTINGER_STATIC_SUBDIR=app,
#     el HTML pedirá /app/assets/… y aquí no existen esos ficheros → el servidor
#     devuelve index.html y el navegador marca error MIME en los .js.
#   • Si la carpeta no se llama hostal-web, cámbiala en las 3 reglas …/frontend/dist/
#
# Error 500: comenta las dos RewriteRule con [P] (proxy) si mod_proxy no está permitido.
#
# deploy/remote-deploy.sh crea solo (SPA en raíz, sin HOSTINGER_STATIC_SUBDIR) el enlace
#   public_html/assets → hostal-web/frontend/dist/assets
# para que /assets/*.js tenga MIME correcto en Hostinger/LiteSpeed. Omitir con
# HOSTINGER_SKIP_ASSETS_SYMLINK=1. A mano, desde public_html:
#   ln -sfn hostal-web/frontend/dist/assets assets
# =============================================================================

<IfModule mod_rewrite.c>
# Si el symlink public_html/assets existe pero sigues viendo text/html en .js, el servidor
# puede no seguir enlaces: prueba descomentar la siguiente línea (si da 500, déjala comentada).
# Options +FollowSymLinks
RewriteEngine On
RewriteBase /

RewriteRule ^api/(.*)$ http://127.0.0.1:8787/api/$1 [P,L]
RewriteRule ^uploads/(.*)$ http://127.0.0.1:8787/uploads/$1 [P,L]

# Servir ficheros reales bajo public_html ANTES del fallback SPA (imprescindible con
# symlink assets → dist: sin esto LiteSpeed suele devolver index.html para /assets/*.js).
RewriteCond %{REQUEST_URI} ^/assets/
RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI} -f
RewriteRule ^ - [L]

RewriteRule ^$ hostal-web/frontend/dist/index.html [L]

# Vite: /assets/* (más compatible que %{REQUEST_URI} en sustitución en algunos LiteSpeed)
RewriteCond %{DOCUMENT_ROOT}/hostal-web/frontend/dist/assets/$1 -f
RewriteRule ^assets/(.+)$ hostal-web/frontend/dist/assets/$1 [L]

# Raíz del dist: favicon.svg, etc.
RewriteCond %{DOCUMENT_ROOT}/hostal-web/frontend/dist/$1 -f
RewriteRule ^(.+)$ hostal-web/frontend/dist/$1 [L]

RewriteRule ^ hostal-web/frontend/dist/index.html [L]

</IfModule>
