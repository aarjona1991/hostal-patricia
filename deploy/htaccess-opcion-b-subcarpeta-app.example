# =============================================================================
# SOLO si quieres la SPA en https://tudominio.com/app/ (no en la raíz)
# =============================================================================
# En .env del monorepo: HOSTINGER_STATIC_SUBDIR=app
# El deploy copia el build a public_html/app/
#
# API: copia hostal-api-proxy.php.example → public_html/hostal-api-proxy.php (sin WebAdmin).
# =============================================================================

<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

RewriteRule ^api/(.*)$ hostal-api-proxy.php?__prefix=api&__p=$1 [B,L,QSA]
RewriteRule ^uploads/(.*)$ hostal-api-proxy.php?__prefix=uploads&__p=$1 [B,L,QSA]
RewriteRule ^hostal-api-proxy\.php$ - [L]

RewriteRule ^$ /app/ [R=302,L]

# /app y /app/ — si no, al ser "app" un directorio falla el fallback con !-d
RewriteRule ^app/?$ app/index.html [L]

RewriteCond %{REQUEST_URI} ^/app/
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

RewriteCond %{REQUEST_URI} ^/app/
RewriteRule ^app/ app/index.html [L]

</IfModule>
