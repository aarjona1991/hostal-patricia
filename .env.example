## Hostinger — Aplicación Node.js en hPanel
# SERVE_FRONTEND=1
# No definas PORT aquí: lo inyecta el panel. Si no carga el proxy: BIND_HOST=0.0.0.0
# BIND_HOST=0.0.0.0
#
# Opcional: solo si autodetect falla. Una variable, ruta ABSOLUTA al monorepo (donde está package.json con workspaces).
# Ejemplo (ajusta usuario/dominio; en SSH: pwd desde la raíz del repo clonado):
# MONOREPO_ROOT=/home/u436615679/domains/casapatriciacubastay.com/nodejs/app
# Inválido (no empieza por /): domains/... o MONOREPO_ROOT=MONOREPO_ROOT=...

## Hostinger — Apache / public_html (sin Aplicación Node; .htaccess sirve el front)
#
# Layout plano (repo en la raíz de public_html: package.json junto a .htaccess):
#   No definas HOSTINGER_STATIC_SUBDIR → VITE_BASE=/ → build en frontend/dist/
#   .htaccess: deploy/hostinger-public-html-flat.htaccess.example
#
# Layout con subcarpeta (ej. public_html/hostal-web/):
#   Mismo .env (sin HOSTINGER_STATIC_SUBDIR si la SPA va en /; el .htaccess apunta a hostal-web/frontend/dist)
#   .htaccess: deploy/hostinger-public-html.htaccess.example (ajusta el nombre de carpeta en las reglas)
#
# Solo subruta /app/: HOSTINGER_STATIC_SUBDIR=app + deploy/htaccess-opcion-b-subcarpeta-app.example
# HOSTINGER_STATIC_SUBDIR=app

## Backend
PORT=8787
# Por defecto el API solo escucha en 127.0.0.1 (VPS + proxy LiteSpeed). Para exponer en red o Node App: BIND_HOST=0.0.0.0
# BIND_HOST=0.0.0.0
#
# URL pública del sitio (https://tudominio.com) — opcional: para og:image absoluta si el Hero usa /uploads/…
# PUBLIC_SITE_URL=https://www.tudominio.com

# --- Persistencia (producción): una carpeta fuera del repo que se redeploya ---
# Opción A — una sola variable: BD en DATA_DIR/app.db y ficheros en DATA_DIR/uploads.
# Las URLs en la web siguen siendo /uploads/archivo.jpg (no cambian al mover el disco).
#   DATA_DIR=/home/TU_USUARIO/persistent/hostal-patricia
#   mkdir -p "$DATA_DIR/uploads" && chmod 700 "$DATA_DIR"
#
# Opción B — rutas sueltas (anulan DATA_DIR para ese recurso):
#   SQLITE_PATH=/var/lib/hostal-patricia/app.db
#   UPLOAD_DIR=/var/lib/hostal-patricia/uploads
#
# Local: sin DATA_DIR ni rutas explícitas → {raíz del monorepo}/data/app.db y …/data/uploads (misma carpeta data/).
# Si usas DATA_DIR en producción, comenta la siguiente línea para que la BD sea DATA_DIR/app.db (no solo las subidas).
SQLITE_PATH=./data/app.db

# REQUIRED for auth
JWT_SECRET=change-me
ADMIN_USERNAME=admin
# Create with: node -e "import('bcrypt').then(m=>m.default.hash('yourpass',10)).then(console.log)"
ADMIN_PASSWORD_HASH=

# Panel /admin: sección «Publicidad» (AdSense). Por defecto visible. Ocultar: ADMIN_SHOW_ADVERTISING=0
# ADMIN_SHOW_ADVERTISING=0

# Notificaciones del formulario de contacto (SMTP)
# Obligatorios para enviar correo: SMTP_HOST, SMTP_USER, SMTP_PASS, CONTACT_NOTIFY_TO
# Ejemplo Hostinger (puerto 587, STARTTLS):
# CONTACT_NOTIFY_TO=tu@email.com
# MAIL_FROM="Casa Patricia Cuba Stay <reservas@casapatriciacubastay.com>"
# Opcional: nombre en la cabecera del correo HTML (si no, se usa el nombre antes de < en MAIL_FROM)
# MAIL_BRAND_NAME=Casa Patricia Cuba Stay
# Opcional: enlace “Visitar sitio web” al pie del correo
# MAIL_SITE_URL=https://casapatriciacubastay.com
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=noreply@casapatriciacubastay.com
# SMTP_PASS=contraseña_del_buzón_noreply
# Si 587 falla con TLS: prueba SMTP_PORT=465 y SMTP_SECURE=1, o SMTP_REQUIRE_TLS=0
# Si tu servidor no usa contraseña: SMTP_ALLOW_NO_PASS=1

