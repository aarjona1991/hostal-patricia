## Backend
PORT=8787
SQLITE_PATH=./data/app.db
# Opcional: carpeta absoluta para imágenes subidas (por defecto ./data/uploads)
# UPLOAD_DIR=

# REQUIRED for auth
JWT_SECRET=change-me
ADMIN_USERNAME=admin
# Create with: node -e "import('bcrypt').then(m=>m.default.hash('yourpass',10)).then(console.log)"
ADMIN_PASSWORD_HASH=

# Notificaciones del formulario de contacto (SMTP)
# CONTACT_NOTIFY_TO=reservas@tudominio.com
# MAIL_FROM="Casa Trinidad Viva <noreply@tudominio.com>"
# SMTP_HOST=smtp.tudominio.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=tu_usuario_smtp
# SMTP_PASS=tu_contraseña_o_app_password
# Si tu servidor no usa contraseña: SMTP_ALLOW_NO_PASS=1

